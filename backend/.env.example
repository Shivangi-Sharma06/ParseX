# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB (required)
# Example format:
# mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/parsex

# JWT (required)
JWT_SECRET=7dbc4222aba38dae96d9eb98fe930ec3dea65f2adf33d38d42ddef0f5afb615e
JWT_EXPIRES_IN=7d

# SMTP (required for shortlist email features)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="ResumeIQ Hiring <noreply@resumeiq.com>"

# OpenAI analysis (optional; app falls back to heuristic if missing)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini

# Optional conventional runtime flag (not directly read in source)
# NODE_ENV=development
